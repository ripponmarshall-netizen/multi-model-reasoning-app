# Frontend (Vite) — set in the deploy environment / GitHub Actions variable.
# URL of your Convex deployment that hosts the guarded backend.
VITE_CONVEX_URL=

# Convex backend secrets — set with the Convex dashboard or:
#   npx convex env set OPENAI_API_KEY ...
# All are OPTIONAL. With no keys, deterministic local demo analyses keep the
# whole app runnable offline.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
LIVE_TRADING_ENABLED=false
